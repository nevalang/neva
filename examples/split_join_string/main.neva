import {
	strings
	fmt
	runtime
}

def Main(start any) (stop any) {
		println fmt.Println<string>
		split strings.Split
		join strings.Join
		panic runtime.Panic
		---
		:start -> [
				'neva' -> split:data,
				'' -> split:delim,
				'' -> join:sep
		]
		split -> join:data
		join -> println:data
		println:res -> :stop
		println:err -> panic
}
