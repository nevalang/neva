import {
	fmt
	runtime
}

def Main(start any) (stop any) {
	println fmt.Println<any>
	gt Gt
	ternary Ternary<any>
	panic runtime.Panic
	---
	:start -> [
		50 -> gt:left,
		10 -> gt:right
	]
	gt:res -> [
		ternary:if,
		'Actual is greater' -> ternary:then,
		'Actual is lower' -> ternary:else
	]
	ternary:res -> println:data
	println:res -> :stop
	println:err -> panic
}
