// Benchmarks the atomic builtin.FanIn hot path.
// Two input ranges feed FanIn, and Wait is only the terminal sink.
import { streams }

def Main(start any) (stop any) {
	left_range streams.Range
	right_range streams.Range
	fan_in FanIn<stream<int>>
	wait streams.Wait
	---
	:start -> [
		1 -> left_range:from,
		100000 -> left_range:to,
		1 -> right_range:from,
		100000 -> right_range:to
	]
	left_range -> fan_in:data[0]
	right_range -> fan_in:data[1]
	fan_in -> wait -> :stop
}
