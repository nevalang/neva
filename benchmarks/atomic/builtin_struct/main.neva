// Benchmarks builtin component `Struct` in one-shot mode.
type User struct {
	name string
	age int
}

// Main builds User via Struct<User> field ports to benchmark typed struct assembly.
def Main(start any) (stop any) {
	builder Struct<User>
	---
	:start -> [
		'John' -> builder:name,
		32 -> builder:age
	]
	builder -> :stop
}
