// Benchmarks builtin component `Get` error-path in one-shot mode.
const value dict<string> = {
	answer: '42'
}

// Main requests a missing key to benchmark Get's error outport under deterministic input.
def Main(start any) (stop any) {
	dict_key Get<string>
	del Del
	---
	:start -> [
		$value -> dict_key:dict,
		'missing' -> dict_key:key
	]
	dict_key:res -> del
	dict_key:err -> :stop
}
