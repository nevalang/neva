// Benchmarks builtin component `Union` in one-shot mode.
type MaybeInt union {
	Some int
	None
}

// Main boxes an int into MaybeInt::Some, exercising tagged-union construction.
def Main(start any) (stop any) {
	box Union<MaybeInt>
	---
	:start -> [
		42 -> box:data,
		MaybeInt::Some -> box:tag
	]
	box -> :stop
}
