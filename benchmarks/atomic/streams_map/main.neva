// Benchmarks the atomic streams.Map hot path with a neutral pass-through handler.
// FromList and FromStream are kept only as the minimal support wiring for a
// valid standalone stream program.
import { lists }
import { streams }

const input list<int> = [1]

// Main maps a one-item stream through Identity to isolate streams.Map dispatch overhead.
def Main(start any) (stop any) {
	to_stream streams.FromList<int>
	map_passthrough streams.Map<int, int>{Identity}
	to_list lists.FromStream<int>
	---
	:start -> $input -> to_stream -> map_passthrough -> to_list -> :stop
}

// Identity returns input unchanged so measured cost stays in stream plumbing.
def Identity(data int) (res int) {
	:data -> :res
}
