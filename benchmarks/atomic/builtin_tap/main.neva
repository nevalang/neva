// Benchmarks builtin component `Tap` in one-shot mode.
import {
	errors
	runtime
}

def Main(start any) (stop any) {
	tap Tap<int>{Handler}
	panic runtime.Panic
	---
	:start -> 42 -> tap:data
	tap:res -> :stop
	tap:err -> panic
}

def Handler(data int) (res any, err error) {
	switch_router Switch<int>
	make_err errors.New
	---
	:data -> [
		switch_router:data,
		0 -> switch_router:case[0]
	]
	switch_router:else -> :res
	switch_router:case[0] -> 'unexpected zero branch' -> make_err -> :err
}
